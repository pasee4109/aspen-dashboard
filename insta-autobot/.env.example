# ── insta-autobot configuration ─────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.  With no .env at all the
# bot runs in MOCK mode: every "send DM" is logged instead of hitting Instagram.

# MODE: "mock" (default) logs actions only. "live" calls the Instagram Graph API.
BOT_MODE=mock

# Port for the dashboard + webhook server.
PORT=3000

# ── Instagram Graph API (only needed when BOT_MODE=live) ─────────────────────
# Create a Meta app, connect an Instagram Professional (Business/Creator)
# account through a Facebook Page, and grant these permissions:
#   instagram_manage_comments, instagram_manage_messages, pages_manage_metadata
# See README.md → "Going live" for the full walkthrough.

# Page access token (long-lived) with the permissions above.
IG_ACCESS_TOKEN=

# The Instagram Business account id (numeric).
IG_ACCOUNT_ID=

# Any random string you choose; must match what you type into the Meta webhook
# setup screen ("Verify Token").
WEBHOOK_VERIFY_TOKEN=change-me
